      <div>
        <h2 class="section-title">One step of the protocol, <em>up close</em>. PR ref in, signed decision out.</h2>
        <p class="section-lede">
          <span class="mono mono-seal">sigil eval &lt;pr-ref&gt;</span> is the mechanics of steps 04 and 05 above. It resolves the PR to an image digest, decrypts the scenario bundle, deploys PR and baseline side-by-side, runs three tiers of Lua scenarios against both, computes a baseline-relative satisfaction score, appends <span class="mono">eval.complete</span> and <span class="mono">eval.decision</span> to the git-backed ledger, and emits feedback stripped of any content the authoring agent is not permitted to see.
        </p>
      </div>
    </div>

    <div class="eval-flow">
      <svg viewBox={`0 0 ${W} ${H}`} preserveAspectRatio="xMidYMid meet" width="100%">
        <g stroke="var(--ink-800)" stroke-width="0.5">
          {Array.from({ length: 13 }).map((_, i) => (
            <line x1={PAD + (INNER_W / 12) * i} y1={Y_LINE - 70} x2={PAD + (INNER_W / 12) * i} y2={Y_LINE - 66} />
          ))}
        </g>

        <line x1={PAD} y1={Y_LINE} x2={W - PAD} y2={Y_LINE} stroke="var(--ink-700)" stroke-width="1" />
        <line x1={PAD + STEP * 2} y1={Y_LINE + 34} x2={PAD + STEP * 4} y2={Y_LINE + 34} stroke="var(--ink-700)" stroke-width="1" stroke-dasharray="2 3" />
        <line x1={PAD + STEP * 2} y1={Y_LINE} x2={PAD + STEP * 2} y2={Y_LINE + 34} stroke="var(--ink-700)" stroke-width="0.6" stroke-dasharray="2 3" />
        <line x1={PAD + STEP * 4} y1={Y_LINE} x2={PAD + STEP * 4} y2={Y_LINE + 34} stroke="var(--ink-700)" stroke-width="0.6" stroke-dasharray="2 3" />
        <text x={PAD + STEP * 3} y={Y_LINE + 50} fill="var(--ink-500)" font-family="JetBrains Mono, monospace" font-size="9" text-anchor="middle" letter-spacing="1.5">BASELINE</text>

        {nodePositions.map((n, i) => (
          <g>
            <circle cx={n.x} cy={n.y} r="7" fill="var(--ink-900)" stroke="var(--ink-500)" stroke-width="1" />
            <circle cx={n.x} cy={n.y} r="2" fill="var(--seal-dim)" />
