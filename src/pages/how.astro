        <text x="30" y="38" fill="var(--ink-500)" font-family="JetBrains Mono, monospace" font-size="9" letter-spacing="1.5">SIGIL · EVAL PIPELINE · FIG.02</text>
        <text x={W - 30} y="38" fill="var(--ink-500)" font-family="JetBrains Mono, monospace" font-size="9" letter-spacing="1.5" text-anchor="end">PROVENANCE TUPLE: 6-FIELD</text>
      </svg>
