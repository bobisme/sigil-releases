            </text>
            <text x={n.x} y={n.y + 22} fill="var(--ink-500)" font-family="JetBrains Mono, monospace" font-size="9" text-anchor="middle" letter-spacing="0.5">
              {n.sub}
            </text>
          </g>
        ))}

        <g id="eval-flow-tokens"></g>

        <g font-family="JetBrains Mono, monospace" font-size="9" letter-spacing="1.5">
          <line x1={PAD + STEP * 6 + 20} y1={Y_LINE - 18} x2={W - PAD + 10} y2={Y_LINE - 18} stroke="var(--allow-dim)" stroke-width="0.6" />
          <line x1={PAD + STEP * 6 + 20} y1={Y_LINE} x2={W - PAD + 10} y2={Y_LINE} stroke="var(--review-dim)" stroke-width="0.6" />
          <line x1={PAD + STEP * 6 + 20} y1={Y_LINE + 18} x2={W - PAD + 10} y2={Y_LINE + 18} stroke="var(--block-dim)" stroke-width="0.6" />
