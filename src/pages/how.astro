<script>
  // =========================================================
  // EVAL FLOW — ambient token animation
  // =========================================================
  (function() {
    const group = document.getElementById('eval-flow-tokens');
    if (!group) return;
    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (reduced) return;

    const W = 1200, PAD = 60;
    const INNER_W = W - PAD * 2;
    const Y_LINE = 140;
    const N_STAGES = 7;
    const STEP = INNER_W / (N_STAGES - 1);
    const LAST_STAGE_X = PAD + STEP * 6;

    let tokens: { id: number; kind: 'allow' | 'review' | 'block'; start: number; duration: number; el: SVGCircleElement }[] = [];
    let tokenId = 0;

    const COLOR = {
      allow:  'oklch(0.74 0.12 155)',
      review: 'oklch(0.80 0.13 85)',
      block:  'oklch(0.64 0.18 25)',
    } as const;

    const NS = 'http://www.w3.org/2000/svg';

    function spawn() {
      const verdict = Math.random();
      const kind: 'allow' | 'review' | 'block' =
        verdict > 0.75 ? 'block' : verdict > 0.55 ? 'review' : 'allow';
      const el = document.createElementNS(NS, 'circle');
      el.setAttribute('r', '2.4');
      el.setAttribute('fill', COLOR[kind]);
      el.setAttribute('cx', String(PAD));
      el.setAttribute('cy', String(Y_LINE));
      group!.appendChild(el);
      tokens.push({
        id: tokenId++,
        kind,
        start: performance.now(),
        duration: 9000 + Math.random() * 1500,
        el,
      });
    }

    function tick() {
      const now = performance.now();
      for (let i = tokens.length - 1; i >= 0; i--) {
        const t = tokens[i];
        const elapsed = now - t.start;
        const p = Math.min(1, elapsed / t.duration);
        if (p >= 1) {
          t.el.remove();
          tokens.splice(i, 1);
          continue;
        }
        const x = PAD + p * INNER_W;
        let y = Y_LINE;
        if (x >= LAST_STAGE_X - 10) {
          const localP = Math.min(1, (x - (LAST_STAGE_X - 10)) / 30);
          if (t.kind === 'allow')  y = Y_LINE - 18 * localP;
          if (t.kind === 'block')  y = Y_LINE + 18 * localP;
        }
        let opacity = 1;
        if (p < 0.05) opacity = p * 20;
        else if (p > 0.9) opacity = (1 - p) * 10;
        t.el.setAttribute('cx', String(x));
        t.el.setAttribute('cy', String(y));
        t.el.setAttribute('opacity', String(Math.max(0, Math.min(1, opacity))));
      }
      requestAnimationFrame(tick);
    }

    spawn();
    setInterval(spawn, 1600);
    requestAnimationFrame(tick);
  })();
</script>
