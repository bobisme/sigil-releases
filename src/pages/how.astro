      <div class="prov-cell"><div class="prov-k">scenario set</div><div class="prov-v">set:auth.v12</div></div>
      <div class="prov-cell"><div class="prov-k">rng seed</div><div class="prov-v">0xDEADB2B5</div></div>
      <div class="prov-cell"><div class="prov-k">control ref</div><div class="prov-v">ctrl:2026.04.12</div></div>
