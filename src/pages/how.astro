// =========================================================
// MARKDOWN SPEC — the human-written source that compiles
// into the billing/upgrade scenario shown in §04
// =========================================================
const SPEC_DOC = `---
title: "Billing — self-serve plan upgrade"
owner: "@jordan"
priority: P0
---

# Self-serve plan upgrade

A free-tier user should upgrade to Pro from the dashboard without
talking to sales. The upgrade must charge the card, reflect in the
subscription API, and send a clean receipt.

## Plans and price

| Plan | Monthly | Annual |
|------|---------|--------|
| Free | $0      | —      |
| Pro  | $12/mo  | $99/yr |

Annual is the default selection in the upgrade UI.

## Acceptance criteria

1. A free account hits \`POST /api/signup\` and receives a \`session_token\`.
2. With that session, the user opens \`/account/billing\`, picks Pro
   (annual), and completes Stripe checkout using \`4242 4242 4242 4242\`
   without leaving the dashboard.
3. After checkout, the Pro plan badge is visible and a "Cancel plan"
   action is available.
4. \`GET /api/subscription\` returns \`{ "plan": "pro", "status": "active" }\`
   on the next read.

## Invariants

- \`GET /api/subscription\` is a **pure read**. N reads in any order
  return the same plan, regardless of \`X-Request-Id\`.
- Upgrades are **idempotent** at the payment_intent layer: a repeated
  checkout for the same intent must not double-charge.

## Quality bar (LLM-judged)

The receipt email copy is professional, free of typos, and names the
correct plan, price, and next billing date.`;

function escapeHtml(s: string) {
  return s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
}
function highlightInline(html: string) {
  // inline `code`
  html = html.replace(/`([^`]+)`/g, '<span class="md-code">`$1`</span>');
  // bold **text**
  html = html.replace(/\*\*([^*]+)\*\*/g, '<span class="md-bold">**$1**</span>');
  return html;
}

function renderMarkdownLines(src: string) {
  const lines = src.split('\n');
  let inFrontmatter = false;
  let seenFirst = false;
  const out: Array<{ cls: string; html: string }> = [];
  for (const line of lines) {
    if (line === '---') {
      if (!seenFirst) {
        seenFirst = true;
        inFrontmatter = true;
        out.push({ cls: 'md-frontmatter-delim', html: escapeHtml(line) });
        continue;
      }
      if (inFrontmatter) {
        inFrontmatter = false;
        out.push({ cls: 'md-frontmatter-delim', html: escapeHtml(line) });
        continue;
      }
      out.push({ cls: 'md-hr', html: escapeHtml(line) });
      continue;
    }
    if (inFrontmatter) {
      out.push({ cls: 'md-frontmatter', html: escapeHtml(line) });
      continue;
    }
    const h = line.match(/^(#{1,6})\s+(.*)$/);
    if (h) {
      out.push({ cls: `md-heading md-h${h[1].length}`, html: escapeHtml(line) });
      continue;
    }
    if (/^\|/.test(line)) {
      out.push({ cls: 'md-table', html: highlightInline(escapeHtml(line)) });
      continue;
    }
    if (/^\s*[-*]\s/.test(line) || /^\s*\d+\.\s/.test(line)) {
      out.push({ cls: 'md-list', html: highlightInline(escapeHtml(line)) });
      continue;
    }
    if (line.trim() === '') {
      out.push({ cls: 'md-blank', html: '' });
      continue;
    }
    out.push({ cls: 'md-plain', html: highlightInline(escapeHtml(line)) });
  }
  return out;
}
const mdLines = renderMarkdownLines(SPEC_DOC);

// =========================================================
// TERMINAL OUTPUTS — small markup helper
// {arrow:▸}, {ok:pass}, {fail:fail}, {warn:REVIEW}, {dim:…}, {meta:(4.2s)},
// {strong:bone}, {seal:accent} — expanded at build time.
// =========================================================
function term(s: string) {
  const escaped = s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
  // process escaped version (markup tokens are safe ASCII so they survive)
  return escaped.replace(/\{(\w+):((?:[^{}]|\{[^}]*\})*)\}/g, (_m, tag, content) => `<span class="t-${tag}">${content}</span>`);
}

