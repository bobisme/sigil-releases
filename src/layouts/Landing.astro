---
interface Props {
  title: string;
  description?: string;
  canonicalPath?: string;
  ogImage?: string;
  jsonLd?: unknown[];
}
import Analytics from '../components/Analytics.astro';
import { SITE, absoluteUrl, jsonLd } from '../lib/site';

const {
  title,
  description = SITE.description,
  canonicalPath = Astro.url.pathname,
  ogImage = SITE.ogImage,
  jsonLd: schemas = [],
} = Astro.props;
const canonical = absoluteUrl(canonicalPath);
---
<!doctype html>
<html lang="en" data-aesthetic="cryptographic">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/manifest.webmanifest" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Inter:wght@300;400;500;600&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:site_name" content="Sigil" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    {schemas.map((schema) => <script type="application/ld+json" set:html={jsonLd(schema)} />)}
    <Analytics />
  </head>
  <body data-aesthetic="cryptographic">
    <a class="skip-link" href="#main">Skip to content</a>
    <slot />
  </body>
</html>

<style is:global>
  /* =========================================================
     SIGIL — DESIGN TOKENS
     ========================================================= */
  :root {
    /* Base — ink & bone */
    --ink-900: oklch(0.10 0.008 240);
    --ink-850: oklch(0.13 0.009 240);
    --ink-800: oklch(0.16 0.010 240);
    --ink-700: oklch(0.22 0.011 240);
    --ink-600: oklch(0.32 0.012 240);
    --ink-500: oklch(0.50 0.013 240);
    --ink-400: oklch(0.58 0.014 240);
    --ink-300: oklch(0.72 0.012 240);
    --ink-200: oklch(0.84 0.010 80);
    --ink-100: oklch(0.92 0.009 80);
    --bone:    oklch(0.96 0.008 80);

    /* Single accent — aged brass / seal wax */
    --seal:       oklch(0.74 0.11 72);
    --seal-dim:   oklch(0.58 0.09 72);
    --seal-faint: oklch(0.32 0.05 72);

    /* Stoplight — muted, editorial */
    --allow:  oklch(0.74 0.12 155);
    --review: oklch(0.80 0.13 85);
    --block:  oklch(0.64 0.18 25);

    --allow-dim:  oklch(0.42 0.08 155);
    --review-dim: oklch(0.46 0.09 85);
    --block-dim:  oklch(0.38 0.10 25);

    /* Typography */
    --font-display: 'Instrument Serif', 'Iowan Old Style', Georgia, serif;
    --font-body:    'Inter', -apple-system, system-ui, sans-serif;
    --font-mono:    'JetBrains Mono', ui-monospace, 'SF Mono', Menlo, monospace;

    /* Rhythm */
    --rule: 1px solid oklch(0.22 0.011 240);
    --rule-faint: 1px solid oklch(0.18 0.010 240);
    --rule-seal: 1px solid oklch(0.58 0.09 72 / 0.35);

    /* Layout */
    --page-max: 1280px;
    --gutter: 48px;
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }

  html, body {
    background: var(--ink-900);
    color: var(--ink-200);
    font-family: var(--font-body);
    font-size: 16px;
    line-height: 1.55;
    font-weight: 400;
    -webkit-font-smoothing: antialiased;
    text-rendering: optimizeLegibility;
    font-feature-settings: 'ss01', 'cv11';
  }
  body { min-height: 100vh; }
  a { color: inherit; text-decoration: none; }

  .skip-link {
    position: fixed;
    top: 12px;
    left: 12px;
    z-index: 100;
    transform: translateY(-140%);
    background: var(--seal);
    color: var(--ink-900);
    padding: 8px 12px;
    font-family: var(--font-mono);
    font-size: 12px;
  }
  .skip-link:focus { transform: translateY(0); }

  /* Reusable ornaments */
  .mono { font-family: var(--font-mono); font-feature-settings: 'zero'; }
  .display { font-family: var(--font-display); font-weight: 400; letter-spacing: -0.01em; }
  .caps { text-transform: uppercase; letter-spacing: 0.14em; font-size: 11px; font-family: var(--font-mono); font-weight: 500; }
  .caps-seal { text-transform: uppercase; letter-spacing: 0.18em; font-size: 10px; font-family: var(--font-mono); font-weight: 500; color: var(--seal); }

  .rule { height: 1px; background: var(--ink-700); }
  .rule-seal { height: 1px; background: linear-gradient(90deg, transparent, var(--seal-faint), transparent); }

  /* Scrollbar */
  ::-webkit-scrollbar { width: 10px; height: 10px; }
  ::-webkit-scrollbar-track { background: var(--ink-900); }
  ::-webkit-scrollbar-thumb { background: var(--ink-700); border: 2px solid var(--ink-900); border-radius: 6px; }
  ::-webkit-scrollbar-thumb:hover { background: var(--ink-600); }

  ::selection { background: var(--seal-faint); color: var(--bone); }

  /* =========================================================
     TOP NAV
     ========================================================= */
  .top-nav {
    position: sticky;
    top: 0;
    z-index: 50;
    background: oklch(0.10 0.008 240 / 0.82);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: var(--rule);
  }
  .top-nav-inner {
    max-width: var(--page-max);
    margin: 0 auto;
    padding: 14px var(--gutter);
    display: flex;
    align-items: center;
    gap: 40px;
  }
  .brand {
    display: flex;
    align-items: center;
    gap: 12px;
    color: var(--bone);
  }
  .brand-mark { color: var(--seal); display: inline-flex; }
  .brand-word {
    font-family: var(--font-display);
    font-size: 24px;
    letter-spacing: 0.02em;
    font-weight: 400;
  }
  .brand-sub {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--ink-300);
    padding-left: 12px;
    border-left: var(--rule);
    margin-left: 4px;
  }
  .top-nav-links {
    display: flex;
    gap: 28px;
    margin-left: auto;
    align-items: center;
  }
  .top-nav-links a {
    display: inline-flex;
    align-items: center;
    min-height: 44px;
    padding-inline: 8px;
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--ink-300);
    letter-spacing: 0.04em;
    transition: color 120ms;
  }
  .top-nav-links a:hover { color: var(--bone); }
  .top-nav-cta {
    padding: 7px 14px;
    border: var(--rule-seal);
    color: var(--seal);
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    transition: all 120ms;
  }
  .top-nav-cta:hover { background: var(--seal-faint); color: var(--bone) !important; }

  /* =========================================================
     PAGE HEADER — used on /how/ and other deep-dive pages
     ========================================================= */
  .page-header {
    max-width: var(--page-max);
    margin: 0 auto;
    padding: 56px var(--gutter) 24px;
  }
  .page-header .caps-seal {
    margin-bottom: 16px;
    display: inline-block;
  }
  .page-header-title {
    font-family: var(--font-display);
    font-size: clamp(44px, 6vw, 72px);
    line-height: 1.02;
    color: var(--bone);
    letter-spacing: -0.02em;
    font-weight: 400;
    margin: 0;
  }

  /* =========================================================
     HERO
     ========================================================= */
  .hero {
    padding: 64px var(--gutter) 64px;
    max-width: var(--page-max);
    margin: 0 auto;
    position: relative;
  }
  .hero-meta {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    color: var(--ink-500);
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    margin-bottom: 40px;
  }
  .hero-meta-seal { color: var(--seal); }
  .hero-grid {
    display: grid;
    grid-template-columns: 1fr 320px;
    gap: 64px;
    align-items: flex-start;
  }
  .hero-title {
    font-family: var(--font-display);
    font-size: clamp(52px, 7.4vw, 96px);
    line-height: 0.98;
    color: var(--bone);
    letter-spacing: -0.02em;
    font-weight: 400;
    margin-bottom: 22px;
  }
  .hero-title em {
    font-style: italic;
    color: var(--seal);
  }
  .hero-lede {
    font-size: 18px;
    line-height: 1.55;
    color: var(--ink-200);
    max-width: 620px;
    margin-bottom: 24px;
    font-weight: 300;
  }
  .hero-lede strong { color: var(--bone); font-weight: 500; }
  .hero-cta-row {
    display: flex;
    gap: 12px;
    align-items: center;
    margin-bottom: 48px;
    flex-wrap: wrap;
  }
  .hero-cta-primary {
    padding: 12px 22px;
    background: var(--bone);
    color: var(--ink-900);
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-weight: 500;
    transition: transform 120ms;
  }
  .hero-cta-primary:hover { transform: translateY(-1px); }
  .hero-cta-secondary {
    padding: 12px 20px;
    color: var(--ink-200);
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    border: var(--rule);
    transition: all 120ms;
  }
  .hero-cta-secondary:hover { border-color: var(--seal); color: var(--seal); }
  .hero-cta-ghost {
    padding: 12px 4px;
    color: var(--ink-400);
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.08em;
    transition: color 120ms;
  }
  .hero-cta-ghost:hover { color: var(--bone); }

  .hero-install {
    display: inline-grid;
    gap: 8px;
    max-width: 100%;
    padding: 14px 16px;
    border: var(--rule);
    background: rgba(245, 239, 224, 0.03);
    box-shadow: inset 0 1px 0 rgba(245, 239, 224, 0.05);
  }
  .install-command {
    display: flex;
    align-items: center;
    gap: 12px;
    min-width: 0;
  }
  .install-command code {
    flex: 1;
    min-width: 0;
    overflow-wrap: anywhere;
  }
  .copy-install {
    flex: 0 0 auto;
    border: var(--rule-seal);
    background: transparent;
    color: var(--seal);
    min-height: 36px;
    padding: 0 10px;
    font-family: var(--font-mono);
    font-size: 11px;
    cursor: pointer;
  }
  .copy-install::before { content: 'copy'; }
  .copy-install[data-copied='true']::before { content: 'copied'; }
  .hero-install-label {
    color: var(--seal);
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }
  .hero-install code {
    display: block;
    color: var(--bone);
    font-family: var(--font-mono);
    font-size: 13px;
    line-height: 1.5;
    white-space: pre-wrap;
    overflow-wrap: anywhere;
  }

  .hero-specimen {
    border: var(--rule);
    padding: 24px 22px 22px;
    background:
      linear-gradient(135deg, oklch(0.25 0.06 72 / 0.18), transparent 34%),
      linear-gradient(180deg, oklch(0.11 0.015 230), var(--ink-900));
    position: relative;
    overflow: hidden;
    box-shadow:
      inset 0 0 0 1px oklch(0.72 0.10 72 / 0.08),
      0 24px 70px oklch(0 0 0 / 0.38);
  }
  .hero-specimen > * { position: relative; z-index: 1; }
  .hero-specimen::before {
    content: '';
    position: absolute;
    top: -1px; left: -1px;
    width: 34px; height: 18px;
    border-top: 1px solid var(--seal);
    border-left: 1px solid var(--seal);
    box-shadow: 20px 0 0 -19px var(--seal);
  }
  .hero-specimen::after {
    content: '';
    position: absolute;
    bottom: -1px; right: -1px;
    width: 34px; height: 18px;
    border-bottom: 1px solid var(--seal);
    border-right: 1px solid var(--seal);
    box-shadow: -20px 0 0 -19px var(--seal);
  }
  .hero-specimen .specimen-label::after {
    content: '';
    position: absolute;
    inset: 68px -20px auto;
    height: 1px;
    background: linear-gradient(90deg, transparent, oklch(0.74 0.11 72 / 0.35), transparent);
  }
  .specimen-label {
    display: flex;
    justify-content: space-between;
    color: var(--ink-400);
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    margin-bottom: 24px;
    position: relative;
  }
  .specimen-mark {
    display: flex;
    justify-content: center;
    padding: 24px 0 28px;
    color: var(--seal);
  }
  .specimen-mark svg { width: 140px; height: 140px; }
  .specimen-kv {
    display: grid;
    grid-template-columns: 72px 1fr;
    gap: 8px 14px;
    font-family: var(--font-mono);
    font-size: 11px;
    padding-top: 20px;
    border-top: 1px solid oklch(0.74 0.11 72 / 0.16);
  }
  .specimen-kv dt { color: var(--ink-500); }
  .specimen-kv dd { color: var(--ink-200); }
  .specimen-kv dd.seal {
    color: var(--review);
    text-shadow: 0 0 18px oklch(0.80 0.13 85 / 0.22);
  }

  .check-artifact {
    position: relative;
    margin: 0 0 20px;
    padding: 18px;
    border: 1px solid oklch(0.74 0.11 72 / 0.18);
    background:
      repeating-linear-gradient(0deg, transparent 0 13px, oklch(0.74 0.11 72 / 0.035) 14px),
      linear-gradient(180deg, oklch(0.08 0.015 230 / 0.92), oklch(0.055 0.01 230 / 0.98));
    font-family: var(--font-mono);
  }
  .check-artifact::before {
    content: '';
    position: absolute;
    inset: 0 auto 0 0;
    width: 3px;
    background: linear-gradient(180deg, var(--allow), var(--review) 58%, var(--block));
  }
  .check-artifact::after {
    content: '';
    position: absolute;
    top: 50%;
    right: 14px;
    transform: translateY(-50%) rotate(-9deg);
    width: 86px;
    height: 86px;
    border: 1px solid oklch(0.80 0.13 85 / 0.45);
    border-radius: 50%;
    pointer-events: none;
  }
  .check-stamp {
    position: absolute;
    top: 50%;
    right: 27px;
    transform: translateY(-50%) rotate(-9deg);
    width: 60px;
    text-align: center;
    color: oklch(0.80 0.13 85 / 0.28);
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.16em;
    pointer-events: none;
    z-index: 1;
  }
  .check-artifact-head {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 16px;
    margin-bottom: 18px;
  }
  .check-context {
    display: block;
    color: var(--bone);
    font-size: 13px;
    letter-spacing: 0.02em;
  }
  .check-subcontext {
    display: block;
    margin-top: 4px;
    color: var(--ink-500);
    font-size: 9px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }
  .check-status {
    color: var(--ink-950);
    background: var(--review);
    border: 1px solid oklch(0.92 0.08 85 / 0.35);
    padding: 5px 8px;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.12em;
    box-shadow: 0 0 22px oklch(0.80 0.13 85 / 0.16);
  }
  .check-bars {
    display: grid;
    gap: 10px;
    padding-right: 52px;
  }
  .check-bar-row {
    display: grid;
    grid-template-columns: 56px minmax(72px, 1fr) 34px;
    align-items: center;
    gap: 10px;
    color: var(--ink-400);
    font-size: 10px;
  }
  .check-bar-row strong {
    color: var(--ink-100);
    font-size: 11px;
    font-weight: 500;
    text-align: right;
  }
  .check-bar-row.is-hot span:first-child,
  .check-bar-row.is-hot strong {
    color: var(--review);
  }
  .check-track {
    height: 6px;
    background: oklch(0.18 0.015 230);
    border: 1px solid oklch(0.74 0.11 72 / 0.10);
    overflow: hidden;
  }
  .check-fill {
    display: block;
    width: var(--score);
    height: 100%;
  }
  .check-fill.is-allow { background: linear-gradient(90deg, var(--allow-dim), var(--allow)); }
  .check-fill.is-review { background: linear-gradient(90deg, var(--review-dim), var(--review)); }
  .check-fill.is-base { background: linear-gradient(90deg, var(--ink-600), var(--ink-300)); }
  .check-verdict {
    margin-top: 18px;
    padding-top: 14px;
    border-top: 1px dashed oklch(0.74 0.11 72 / 0.18);
    color: var(--bone);
  }
  .verdict-kicker {
    display: block;
    margin-bottom: 4px;
    color: var(--seal);
    font-size: 9px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }
  .check-verdict strong {
    display: block;
    max-width: 190px;
    font-size: 13px;
    line-height: 1.35;
    font-weight: 500;
  }

  /* Decision stamps */
  .decisions {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0;
    border: var(--rule);
    margin-top: 24px;
  }
  .decision {
    padding: 28px 24px;
    position: relative;
  }
  .decision + .decision { border-left: var(--rule); }
  .decision-stamp {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 42px;
    line-height: 1;
    margin-bottom: 14px;
    letter-spacing: -0.01em;
  }
  .decision-exit {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--ink-500);
    margin-bottom: 10px;
  }
  .decision-desc {
    color: var(--ink-300);
    font-size: 13px;
    line-height: 1.5;
  }
  .decision.allow .decision-stamp { color: var(--allow); }
  .decision.review .decision-stamp { color: var(--review); }
  .decision.block .decision-stamp { color: var(--block); }
  .decision-ring {
    position: absolute;
    top: 24px; right: 24px;
    width: 10px; height: 10px;
    border-radius: 50%;
  }
  .decision.allow .decision-ring { background: var(--allow); box-shadow: 0 0 0 3px var(--allow-dim); }
  .decision.review .decision-ring { background: var(--review); box-shadow: 0 0 0 3px var(--review-dim); }
  .decision.block .decision-ring { background: var(--block); box-shadow: 0 0 0 3px var(--block-dim); }

  /* =========================================================
     SECTION FRAME
     ========================================================= */
  .section {
    padding: 96px var(--gutter);
    max-width: var(--page-max);
    margin: 0 auto;
    border-top: var(--rule);
    position: relative;
  }
  .section-head {
    display: grid;
    grid-template-columns: 200px 1fr;
    gap: 32px;
    margin-bottom: 56px;
    align-items: baseline;
  }
  .section-num {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--ink-500);
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }
  .section-num span { color: var(--seal); }
  .section-title {
    font-family: var(--font-display);
    font-size: clamp(36px, 5vw, 56px);
    line-height: 1.05;
    color: var(--bone);
    letter-spacing: -0.015em;
    max-width: 780px;
    font-weight: 400;
  }
  .section-title em { font-style: italic; color: var(--seal); }
  .section-lede {
    font-size: 16px;
    line-height: 1.6;
    color: var(--ink-300);
    max-width: 620px;
    margin-top: 20px;
  }
  .section-lede .mono-seal { color: var(--seal); font-family: var(--font-mono); }

  /* =========================================================
     EVAL FLOW
     ========================================================= */
  .eval-flow {
    border: var(--rule);
    background: var(--ink-850);
    padding: 0;
    position: relative;
  }
  .eval-flow svg { background: var(--ink-850); display: block; }

  /* =========================================================
     PROTOCOL STRIP — five-card lifecycle
     ========================================================= */
  .protocol-strip {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    border: var(--rule);
    list-style: none;
    padding-left: 0;
  }
  .protocol-step {
    padding: 28px 22px 26px;
    border-left: var(--rule);
    position: relative;
    display: flex;
    flex-direction: column;
  }
  .protocol-step:first-child { border-left: none; }
  .protocol-step .step-head {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 8px;
  }
  .protocol-step .step-num {
    width: 26px;
    height: 26px;
    border: 1px solid var(--seal);
    border-radius: 50%;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 600;
    color: var(--seal);
    line-height: 1;
  }
  .protocol-step .step-label {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.16em;
    color: var(--bone);
    text-transform: uppercase;
  }
  .protocol-step .step-actor {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--seal);
    margin-bottom: 14px;
  }
  .protocol-step .step-title {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 24px;
    line-height: 1.15;
    color: var(--bone);
    margin-bottom: 14px;
  }
  .protocol-step .step-note {
    color: var(--ink-300);
    font-size: 13px;
    line-height: 1.55;
  }
  .protocol-step .step-note .mono {
    color: var(--bone);
    font-size: 0.92em;
  }
  .protocol-step .step-loop {
    position: absolute;
    top: 24px;
    right: 20px;
    font-family: var(--font-mono);
    font-size: 18px;
    color: var(--seal);
    line-height: 1;
    cursor: default;
  }

  /* Stacked variant — used on landing where horizontal space
     per card would otherwise be cramped. Aligns left/right grid
     columns with the preceding .section-head (200px 1fr, 32px gap). */
  .protocol-strip.is-stacked {
    grid-template-columns: 1fr;
    border: none;
  }
  .protocol-strip.is-stacked .protocol-step {
    border-left: none;
    border-top: var(--rule);
    padding: 36px 0 38px;
    display: grid;
    grid-template-columns: 200px 1fr;
    gap: 10px 32px;
    align-items: baseline;
  }
  .protocol-strip.is-stacked .step-head {
    grid-column: 1;
    grid-row: 1;
    margin-bottom: 0;
  }
  .protocol-strip.is-stacked .step-actor {
    grid-column: 1;
    grid-row: 2;
    margin-bottom: 0;
  }
  .protocol-strip.is-stacked .step-title {
    grid-column: 2;
    grid-row: 1;
    margin-bottom: 4px;
    font-size: 28px;
  }
  .protocol-strip.is-stacked .step-note {
    grid-column: 2;
    grid-row: 2;
    max-width: 720px;
    font-size: 15px;
    line-height: 1.6;
  }
  .flow-legend {
    display: flex;
    gap: 32px;
    padding: 16px 24px;
    border-top: var(--rule);
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--ink-400);
    letter-spacing: 0.04em;
    flex-wrap: wrap;
  }
  .flow-legend .item { display: flex; align-items: center; gap: 8px; }
  .flow-legend .dot { width: 6px; height: 6px; border-radius: 50%; }

  /* =========================================================
     MARKDOWN SPEC BLOCK
     ========================================================= */
  .md-block {
    border: var(--rule);
    background: var(--ink-850);
  }
  .md-header {
    padding: 14px 20px;
    border-bottom: var(--rule);
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 13px;
    gap: 16px;
    flex-wrap: wrap;
  }
  .md-file { font-family: var(--font-mono); font-size: 13px; }
  .md-meta { display: flex; align-items: center; gap: 12px; }
  .md-body { padding: 24px 0; overflow-x: auto; }
  .md-pre {
    font-family: var(--font-mono);
    font-size: 13px;
    line-height: 1.7;
    color: var(--ink-200);
    padding: 0 20px;
    min-width: 620px;
  }
  .md-line {
    display: flex;
    align-items: baseline;
    gap: 18px;
  }
  .md-ln {
    color: var(--ink-600);
    font-size: 11px;
    user-select: none;
    min-width: 28px;
    text-align: right;
  }
  .md-content { flex: 1; white-space: pre-wrap; word-break: break-word; }

  /* Line-type styling */
  .md-frontmatter-delim .md-content { color: var(--ink-500); }
  .md-frontmatter .md-content { color: var(--ink-400); font-style: italic; }
  .md-heading .md-content { color: var(--seal); font-weight: 600; }
  .md-h1 .md-content { color: var(--bone); }
  .md-hr .md-content { color: var(--ink-500); }
  .md-table .md-content { color: var(--ink-200); }
  .md-list .md-content { color: var(--ink-200); }
  .md-plain .md-content { color: var(--ink-200); }
  .md-blank .md-content::before { content: ' '; }

  /* Inline */
  .md-content .md-code {
    color: var(--seal);
    background: var(--ink-900);
    padding: 0 4px;
    border: var(--rule-faint);
  }
  .md-content .md-bold {
    color: var(--bone);
    font-weight: 600;
  }

  /* Generate command strip */
  .md-generate {
    padding: 18px 20px;
    border-top: var(--rule);
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 20px;
    flex-wrap: wrap;
  }
  .md-generate-cmd {
    font-family: var(--font-mono);
    font-size: 13px;
    color: var(--bone);
    display: flex;
    gap: 10px;
    align-items: baseline;
  }
  .md-generate-prompt {
    color: var(--seal);
    font-weight: 600;
  }
  .md-generate-note {
    color: var(--ink-400);
    font-size: 12px;
    font-family: var(--font-mono);
    letter-spacing: 0.02em;
  }

  /* =========================================================
     COMMAND STACK — §05 THE LOOP
     ========================================================= */
  .cmd-stack {
    display: flex;
    flex-direction: column;
    gap: 32px;
  }
  .cmd-block {
    border: var(--rule);
    background: var(--ink-850);
  }
  .cmd-head {
    display: flex;
    align-items: baseline;
    gap: 14px;
    padding: 14px 20px;
    border-bottom: var(--rule);
    flex-wrap: wrap;
  }
  .cmd-chip {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.12em;
    color: var(--seal);
    border: var(--rule-seal);
    padding: 3px 8px;
    text-transform: uppercase;
  }
  .cmd-actor {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.14em;
    color: var(--seal);
    text-transform: uppercase;
  }
  .cmd-title {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 18px;
    color: var(--bone);
    margin-left: auto;
  }
  .cmd-caption {
    padding: 14px 20px 0;
    color: var(--ink-300);
    font-size: 13px;
    line-height: 1.6;
    max-width: 820px;
  }
  .cmd-caption em { color: var(--bone); font-style: italic; }
  .cmd-caption .mono { color: var(--seal); background: var(--ink-900); padding: 0 4px; border: var(--rule-faint); font-size: 0.9em; }
  .cmd-output {
    margin: 16px 20px 22px;
    padding: 16px 18px;
    background: var(--ink-900);
    border: var(--rule-faint);
    font-family: var(--font-mono);
    font-size: 12px;
    line-height: 1.7;
    color: var(--ink-200);
    white-space: pre;
    overflow-x: auto;
  }

  /* Terminal output token colors */
  .t-arrow  { color: var(--seal); }
  .t-seal   { color: var(--seal); font-weight: 600; }
  .t-strong { color: var(--bone); }
  .t-meta   { color: var(--ink-500); }
  .t-dim    { color: var(--ink-500); }
  .t-ok     { color: var(--allow); }
  .t-fail   { color: var(--block); }
  .t-warn   { color: var(--review); }

  @media (max-width: 900px) {
    .cmd-title { margin-left: 0; }
    .cmd-output { margin: 12px; }
  }

  /* =========================================================
     LUA BLOCK
     ========================================================= */
  .lua-block {
    border: var(--rule);
    background: var(--ink-850);
  }
  .lua-header {
    padding: 14px 20px;
    border-bottom: var(--rule);
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 13px;
    gap: 16px;
    flex-wrap: wrap;
  }
  .lua-file { font-family: var(--font-mono); font-size: 13px; }
  .lua-meta { display: flex; align-items: center; gap: 12px; }
  .lua-dot { width: 4px; height: 4px; background: var(--ink-500); border-radius: 50%; }
  .lua-body { padding: 24px 0; overflow-x: auto; }
  .lua-pre {
    font-family: var(--font-mono);
    font-size: 13px;
    line-height: 1.7;
    color: var(--ink-200);
    padding: 0 20px;
    min-width: 680px;
  }
  .lua-line {
    display: flex;
    align-items: baseline;
    gap: 18px;
    position: relative;
  }
  .lua-line.has-callout { background: linear-gradient(90deg, oklch(0.58 0.09 72 / 0.04), transparent 70%); }
  .lua-ln {
    color: var(--ink-600);
    font-size: 11px;
    user-select: none;
    min-width: 28px;
    text-align: right;
  }
  .lua-code { flex: 1; white-space: pre; }
  .lua-callout-marker {
    position: absolute;
    right: 8px;
    top: 2px;
  }
  .callout-id {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 18px; height: 18px;
    border: 1px solid var(--seal);
    color: var(--seal);
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 600;
    border-radius: 50%;
  }

  /* Lua syntax colors */
  .tok-kw      { color: oklch(0.72 0.12 300); }
  .tok-sigil   { color: var(--seal); font-weight: 500; }
  .tok-string  { color: oklch(0.80 0.10 155); }
  .tok-num     { color: oklch(0.78 0.11 200); }
  .tok-comment { color: var(--ink-500); font-style: italic; }
  .tok-rubric  { color: var(--seal-dim); font-style: italic; }
  .tok-ident   { color: var(--ink-200); }
  .tok-punct   { color: var(--ink-400); }
  .tok-op      { color: var(--ink-300); }
  .tok-ws      { white-space: pre; }
  .tok-other   { color: var(--ink-200); }

  .lua-callouts {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    border-top: var(--rule);
  }
  .callout-card {
    padding: 20px 18px 22px;
    border-left: var(--rule);
  }
  /* First of each row: no left border */
  .callout-card:nth-child(4n+1) { border-left: none; }
  /* Second row: top border */
  .callout-card:nth-child(n+5) { border-top: var(--rule); }
  .callout-head {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 8px;
  }
  .callout-head .line-ref {
    margin-left: auto;
    color: var(--ink-500);
    font-size: 10px;
    font-family: var(--font-mono);
  }
  .callout-api {
    color: var(--bone);
    font-size: 13px;
    font-weight: 500;
  }
  .callout-label {
    margin-bottom: 10px;
    font-size: 9px;
    letter-spacing: 0.2em;
  }
  .callout-note {
    color: var(--ink-300);
    font-size: 12.5px;
    line-height: 1.55;
  }

  /* =========================================================
     EXPECT FAILURE
     ========================================================= */
  .ef-wrap {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
    border: var(--rule);
  }
  .ef-col {
    padding: 24px 24px 28px;
    border-left: var(--rule);
    display: flex;
    flex-direction: column;
  }
  .ef-col:first-child { border-left: none; }
  .ef-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding-bottom: 14px;
    margin-bottom: 14px;
    border-bottom: var(--rule-faint);
    gap: 12px;
    flex-wrap: wrap;
  }
  .ef-side { display: flex; align-items: baseline; }
  .ef-meta {
    font-size: 10px;
    color: var(--ink-500);
    letter-spacing: 0.08em;
  }
  .ef-frame {
    font-family: var(--font-mono);
    font-size: 11.5px;
    line-height: 1.55;
    padding: 18px 18px;
    background: var(--ink-900);
    border: var(--rule-faint);
    color: var(--ink-200);
    overflow-x: auto;
    white-space: pre;
    margin-bottom: 14px;
  }
  .ef-operator { color: var(--ink-200); }
  .ef-operator::first-line { color: var(--block); }
  .ef-agent { color: var(--ink-400); }
  .ef-caption {
    color: var(--ink-300);
    font-size: 13px;
    line-height: 1.6;
  }
  .ef-caption code {
    font-family: var(--font-mono);
    font-size: 0.88em;
    color: var(--seal);
    padding: 0 4px;
    background: var(--ink-850);
    border: var(--rule-faint);
  }
  .ef-caption em { color: var(--bone); font-style: italic; }

  /* =========================================================
     TRUST LADDER
     ========================================================= */
  .ladder-chambers {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    border: var(--rule);
  }
  .chamber {
    padding: 28px 24px 26px;
    border-left: var(--rule);
    position: relative;
  }
  .chamber:first-child { border-left: none; }
  .chamber-head {
    display: flex;
    align-items: baseline;
    gap: 10px;
    margin-bottom: 18px;
  }
  .chamber-roman {
    font-family: var(--font-display);
    font-size: 26px;
    color: var(--ink-500);
    line-height: 1;
  }
  .chamber-name {
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.16em;
    color: var(--bone);
  }
  .chamber-dot {
    margin-left: auto;
    width: 8px; height: 8px; border-radius: 50%;
  }
  .chamber-verb {
    font-size: 28px;
    font-style: italic;
    color: var(--ink-200);
    margin-bottom: 18px;
    line-height: 1.1;
    font-family: var(--font-display);
    font-weight: 400;
  }
  .chamber-rule {
    height: 1px;
    background: linear-gradient(90deg, var(--seal-faint), transparent);
    margin-bottom: 16px;
  }
  .chamber-row {
    display: grid;
    grid-template-columns: 76px 1fr;
    gap: 10px;
    font-size: 12px;
    margin-bottom: 10px;
    align-items: baseline;
  }
  .chamber-k {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.1em;
    color: var(--ink-500);
    text-transform: uppercase;
  }
  .chamber-v {
    color: var(--ink-200);
    font-size: 13px;
    line-height: 1.45;
  }
  .chamber-v.decay { color: var(--block); }
  .chamber-v.muted { color: var(--ink-500); }

  /* =========================================================
     INVARIANT WALL
     ========================================================= */
  .inv-wall {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0;
    border: var(--rule);
  }
  .inv-card {
    padding: 40px 36px 36px;
    border-left: var(--rule);
    border-top: var(--rule);
    position: relative;
    min-height: 340px;
    display: flex;
    flex-direction: column;
  }
  .inv-card:nth-child(odd) { border-left: none; }
  .inv-card:nth-child(-n+2) { border-top: none; }
  .inv-corner {
    position: absolute;
    width: 10px; height: 10px;
    border: 1px solid var(--seal-dim);
  }
  .inv-corner.top-l { top: 10px; left: 10px; border-right: none; border-bottom: none; }
  .inv-corner.top-r { top: 10px; right: 10px; border-left: none; border-bottom: none; }
  .inv-corner.bot-l { bottom: 10px; left: 10px; border-right: none; border-top: none; }
  .inv-corner.bot-r { bottom: 10px; right: 10px; border-left: none; border-top: none; }
  .inv-roman {
    font-family: var(--font-display);
    font-size: 64px;
    line-height: 1;
    color: var(--seal);
    margin-bottom: 8px;
  }
  .inv-name {
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--ink-400);
    margin-bottom: 16px;
  }
  .inv-tagline {
    font-size: 28px;
    font-style: italic;
    color: var(--bone);
    line-height: 1.15;
    margin-bottom: 22px;
    max-width: 400px;
    font-family: var(--font-display);
    font-weight: 400;
  }
  .inv-rule {
    height: 1px;
    background: var(--ink-700);
    margin-bottom: 20px;
    max-width: 80px;
  }
  .inv-body {
    color: var(--ink-300);
    font-size: 14px;
    line-height: 1.6;
    margin-bottom: 20px;
    flex: 1;
  }
  .inv-formal {
    font-size: 11px;
    color: var(--seal-dim);
    padding: 10px 12px;
    background: var(--ink-900);
    border: var(--rule-faint);
    display: inline-block;
    align-self: flex-start;
    font-family: var(--font-mono);
  }

  /* =========================================================
     WHY DARK FACTORY
     ========================================================= */
  .dark-factory {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px;
    align-items: start;
  }
  .df-prose p {
    color: var(--ink-200);
    font-size: 16px;
    line-height: 1.7;
    margin-bottom: 16px;
  }
  .df-prose p em { color: var(--bone); font-style: italic; }
  .df-prose p .mono-em { color: var(--ink-200); font-family: var(--font-mono); }
  .df-prose p.lede {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 26px;
    line-height: 1.3;
    color: var(--bone);
    margin-bottom: 24px;
  }
  .df-diagram {
    border: var(--rule);
    background: var(--ink-850);
    padding: 32px 28px;
  }
  .df-diagram-title {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.16em;
    color: var(--ink-500);
    text-transform: uppercase;
    margin-bottom: 20px;
    display: flex;
    justify-content: space-between;
    gap: 12px;
    flex-wrap: wrap;
  }

  /* =========================================================
     PROVENANCE STRIP
     ========================================================= */
  .prov-strip {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    border: var(--rule);
    margin-top: 24px;
  }
  .prov-cell {
    padding: 18px 16px;
    border-left: var(--rule);
  }
  .prov-cell:first-child { border-left: none; }
  .prov-k {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.12em;
    color: var(--ink-500);
    text-transform: uppercase;
    margin-bottom: 8px;
  }
  .prov-v {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--bone);
    word-break: break-all;
  }

  /* =========================================================
     MARKS SPEC SHEET
     ========================================================= */
  .marks-sheet {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    border: var(--rule);
  }
  .mark-cell {
    padding: 32px 24px 24px;
    border-left: var(--rule);
    text-align: center;
    position: relative;
  }
  .mark-cell:first-child { border-left: none; }
  .mark-cell.active { background: linear-gradient(180deg, oklch(0.58 0.09 72 / 0.08), transparent); }
  .mark-cell.active::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 1px; background: var(--seal);
  }
  .mark-svg-wrap {
    color: var(--seal);
    display: flex;
    justify-content: center;
    margin-bottom: 22px;
  }
  .mark-svg-wrap svg { width: 96px; height: 96px; display: block; }
  .mark-cipher {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.14em;
    color: var(--ink-500);
    text-transform: uppercase;
    margin-bottom: 6px;
  }
  .mark-name {
    font-family: var(--font-display);
    font-size: 22px;
    font-style: italic;
    color: var(--bone);
    margin-bottom: 4px;
  }
  .mark-note {
    font-size: 12px;
    color: var(--ink-400);
  }

  /* =========================================================
     LANDING — PAIN / BENEFIT / AUDIENCE / CTA
     ========================================================= */
  .wall-3 {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    border: var(--rule);
  }
  .wall-2 {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    border: var(--rule);
  }
  .wall-cell {
    padding: 40px 36px 36px;
    border-left: var(--rule);
    position: relative;
    min-height: 280px;
    display: flex;
    flex-direction: column;
  }
  .wall-cell:first-child { border-left: none; }

  .wall-num {
    font-family: var(--font-display);
    font-size: 44px;
    color: var(--seal);
    line-height: 1;
    margin-bottom: 16px;
  }
  .wall-label {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--ink-400);
    margin-bottom: 16px;
  }
  .wall-headline {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 24px;
    color: var(--bone);
    line-height: 1.2;
    margin-bottom: 18px;
    max-width: 360px;
  }
  .wall-2 .wall-headline {
    font-size: 30px;
    max-width: 440px;
  }
  .wall-note {
    color: var(--ink-300);
